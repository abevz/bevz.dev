---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card">
  <div class="card-topline">
    <div>
      <p class="work-label">{project.workLabel}</p>
      <h3>{project.title}</h3>
    </div>
    <span class={`status-pill ${project.status === "Active" ? "active" : "progress"}`}>
      {project.status}
    </span>
  </div>
  <div class="project-detail">
    <span>Problem</span>
    <p>{project.problem}</p>
  </div>
  <div class="project-detail">
    <span>Approach</span>
    <p>{project.approach}</p>
  </div>
  <div class="project-detail">
    <span>Engineering value</span>
    <p class="impact">{project.engineeringValue}</p>
  </div>
  <div class="project-detail">
    <span>Stack</span>
  </div>
  <ul class="chip-list" aria-label={`${project.title} stack`}>
    {project.stack.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <div class="link-row">
    {project.links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>
</article>
