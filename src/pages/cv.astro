---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title="CV — Aleksey Bevz"
  description="CV summary for Aleksey Bevz: DevOps and Platform Engineering experience, certifications, and delivery focus."
>
  <Header />
  <main class="shell section page-top">
    <SectionHeading
      title="Short-form profile"
      intro="Concise overview of platform engineering focus, experience, and certifications."
    />

    <section class="cv-grid">
      <article class="note-card">
        <h3>Role Fit</h3>
        <p>
          Hands-on DevOps / Platform Engineer with production infrastructure
          experience at Ukrenergo and serious production-like platform practice
          around Kubernetes, IaC, CI/CD, observability, registry, DNS/TLS, and
          automation.
        </p>
      </article>
      <article class="note-card">
        <h3>Location</h3>
        <p>{profile.location}</p>
      </article>
      <article class="note-card">
        <h3>Core Strengths</h3>
        <p>
          Reproducible infrastructure, operational debugging, Kubernetes
          platform work, CI/CD cleanup, observability, registry integration, and
          pragmatic automation.
        </p>
      </article>
      <article class="note-card">
        <h3>Certifications</h3>
        <p>{profile.certifications.join(", ")}</p>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>
