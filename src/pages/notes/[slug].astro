---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { notes } from "../../data/notes";

export function getStaticPaths() {
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
---

<BaseLayout
  title={`${note.title} — Aleksey Bevz`}
  description={note.description}
>
  <Header />
  <main class="shell section page-top">
    <article class="note-page">
      <p class="note-kicker">Engineering Note</p>
      <h1>{note.title}</h1>
      <p class="note-lead">{note.description}</p>

      <div class="note-page-meta">
        <ul class="chip-list" aria-label={`${note.title} tags`}>
          {note.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
        <span class="note-status">Planned</span>
      </div>

      <section class="note-section">
        <h2>Planned Coverage</h2>
        <ul class="focus-list">
          {note.outline.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="note-section note-callout">
        <h2>Status</h2>
        <p>
          This page is a preview of the future note layout. The full write-up is
          not published yet.
        </p>
      </section>

      <p class="note-backlink"><a href="/notes">Back to Notes</a></p>
    </article>
  </main>
  <Footer />
</BaseLayout>
