---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Selected Engineering Work — Aleksey Bevz"
  description="Selected DevOps and Platform Engineering projects across Kubernetes, infrastructure automation, observability, and tooling."
>
  <Header />
  <main class="shell section page-top">
    <SectionHeading
      eyebrow="Selected Engineering Work"
      title="Problem-driven platform and infrastructure work"
      intro="These are not generic portfolio cards. Each item is meant to show practical engineering thinking: what problem existed, what approach was taken, and why the solution matters operationally."
    />
    <div class="project-grid">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
