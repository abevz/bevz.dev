---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Selected Engineering Work — Aleksey Bevz"
  description="Selected DevOps and Platform Engineering projects across Kubernetes, infrastructure automation, monitoring, and tooling."
>
  <Header />
  <main class="shell section page-top">
    <SectionHeading
      level={1}
      title="Selected Engineering Work"
      intro="Practical infrastructure work across Kubernetes, CI/CD, monitoring, registry integration, and automation."
    />
    <div class="project-grid">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
